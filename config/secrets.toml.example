# Wenku8Downloader 配置文件模板
# 复制本文件为 secrets.toml，并按需填写对应信息
# cp config/secrets.toml.example config/secrets.toml

[cookie]
# 登录后的 Cookie，可在「配置」页面手动填写或输账号后自动获取
PHPSESSID = ""
jieqiUserInfo = ""
jieqiVisitInfo = ""
cf_clearance = ""

[login]
# 轻小说文库账号（用于自动更新 Cookie 时使用）
username = ""
password = ""

[proxy]
# 代理配置，如遇到网络完全被墙可配置（可选，如 http://127.0.0.1:7897）
# 留空则系统自动直连
http = ""
https = ""

[download]
# 书名格式：FULL（完整）/ OUT（括号外）/ IN（括号内）
# 例：「败北女角太多了！(败犬女主太多了！)」
#   FULL -> 败北女角太多了！(败犬女主太多了！)
#   OUT  -> 败北女角太多了！
#   IN   -> 败犬女主太多了！
full_title = "FULL"

# 封面图片索引（0 表示第一张插图）
default_cover_index = 0
